{
  "name": "suprsend-react-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/es/index.js"
    },
    "./styles.css": {
      "import": "./dist/es/styles.css",
      "require": "./dist/cjs/styles.css"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "dev": "yarn build:es --watch && yarn build:cjs --watch",
    "build": "yarn clean && tsc -b && yarn build:cjs && yarn build:es",
    "build:cjs": "BUILD_TARGET=cjs  vite build",
    "build:es": "BUILD_TARGET=es  vite build",
    "lint": "eslint ."
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "class-variance-authority": "0.6.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "emoji-picker-element": "^1.29.0",
    "handlebars": "^4.7.8",
    "lodash.clonedeep": "^4.5.0",
    "lodash.isempty": "^4.4.0",
    "lucide-react": "^0.553.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^3.0.6",
    "react-select": "^5.10.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "textarea-caret": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/lodash.isempty": "^4.4.9",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/textarea-caret": "^3.0.4",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.22",
    "babel-plugin-react-require": "^4.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.0",
    "tailwindcss": "3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-svgr": "^4.5.0"
  }
}
